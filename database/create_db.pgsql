 on ingest_Data.py\n\nCREATE TABLE IF NOT EXISTS animals (\n    animal_id UUID PRIMARY KEY,\n    name TEXT NOT NULL,\n    scientific_name TEXT NOT NULL,\n    image_url TEXT,\n    locations JSONB,\n    kingdom TEXT,\n    class TEXT,\n    average_age TEXT,\n    size TEXT,\n    weight TEXT\n);\n\n-- Index for faster lookups by scientific name (used in existence check)\nCREATE INDEX IF NOT EXISTS idx_animals_scientific_name ON animals(scientific_name);\n","kind":"sql","language":"sql"},{"value":"CREATE INDEX idx_animals_name ON animals(name);\nCREATE INDEX idx_animals_conservation ON animals(conservation_status);\n","kind":"sql","language":"sql"},{"value":"CREATE TABLE animal_distribution_grids (\n    grid_id UUID PRIMARY KEY,\n\n    animal_id UUID REFERENCES animals(animal_id) ON DELETE CASCADE,\n\n    grid_lat DOUBLE PRECISION NOT NULL,\n    grid_lng DOUBLE PRECISION NOT NULL,\n\n    grid_size_km NUMERIC(6,2) NOT NULL,        -- size of grid cell\n    density_score NUMERIC(6,3) NOT NULL,       -- normalized density\n    occurrence_count INT NOT NULL,             -- raw count inside cell\n\n    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n);\n","kind":"sql","language":"sql"},{"value":"CREATE INDEX idx_grid_animal ON animal_distribution_grids(animal_id);\n\nCREATE INDEX idx_grid_lat_lng \nON animal_distribution_grids(grid_lat, grid_lng);\n","kind":"sql","language":"sql"}],"metadata":{"connectionId":"1770054557613","databaseName":"bio_geo_guesser","host":"localhost","port":5432,"username":"root","password":"root","custom":{"cells":[],"metadata":{"connectionId":"1770054557613","databaseName":"bio_geo_guesser","host":"localhost","port":5432,"username":"root","password":"root","custom":{"cells":[{"value":"### 📝 Query Tool: `bio_geo_guesser`\n\n<div style=\"font-size: 12px; background-color: rgba(52, 152, 219, 0.1); border-left: 3px solid #3498db; padding: 6px 10px; margin-bottom: 15px; border-radius: 3px; color: var(--vscode-editor-foreground);\">\n    <strong>ℹ️ Note:</